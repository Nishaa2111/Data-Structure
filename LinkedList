#include<iostream>
using namespace std;
struct node {
    int data;
    node *next;
};
int main() {
    node *head = NULL, *temp, *newnode;
    int ch, n, i;
    char x;

    do {
        cout<<"\n linked list menu";
        cout<<endl<<"Create linked list";
        cout<<endl<<"Insertion at beginning";
        cout<<endl<<"Insertion at end";
        cout<<endl<<"Display";
        cout<<endl<<"Enter your choice";
        cin>>ch;

        switch(ch) {
            case 1:
            cout<<"enter number of nodes:";
            cin>> n;
            for(i=1;i<=n;i++){
                newnode = new node;
                cout<<"enter data :";
                cin>>newnode->data;
                newnode->next = NULL;
                if(head == NULL){
                    head = newnode;
                    temp = head;
                }
                else {
                    temp->next = newnode;
                    temp = newnode;
                }
            }
            break;

            case 2:
            newnode = new node;
            cout<<"enter value:";
            cin>>newnode->data;

            newnode->next = head;
            head = newnode;
            break;

            case 3:
            newnode = new node;
            cout<<"enter value:";
            cin>>newnode->data;
            newnode->next = NULL;
            if(head == NULL){
                head = newnode;
            }
            else {
                temp = head;
                while(temp->next != NULL){
                    temp = temp->next;
                }
                temp->next = newnode;
            }
            break;
            
            case 4:
            if(head == NULL){
                cout<<"list is empty";
            }
            else {
                temp = head;
                cout<<"linked list:"<<endl;
                while (temp != NULL){
                    cout<<temp->data<<"->";
                    temp = temp->next;
                }
                cout<<"NULL";
            }
            break;

            default:
            cout<<"Invalid choice";  
        }
        cout<<endl<<"do you want to continue";
        cin>>x;
    }
    while(x == 'y' || x == 'Y');
    return 0;
}
